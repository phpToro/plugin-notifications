{
    "name": "Notifications",
    "namespace": "notifications",
    "platforms": {
        "ios": {
            "handlers": ["ios/NotificationsHandler.swift"],
            "frameworks": ["UserNotifications"],
            "permissions": [
                {
                    "key": "NSUserNotificationsUsageDescription",
                    "description": "This app needs permission to send notifications"
                }
            ]
        },
        "macos": {
            "handlers": ["macos/NotificationsHandler.swift"],
            "frameworks": ["UserNotifications"]
        }
    },
    "js": ["js/notifications.js"],
    "php": {
        "files": ["php/Notifications.php"]
    }
}
